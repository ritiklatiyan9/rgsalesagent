{
  "appId": "com.rivergreen.agent",
  "appName": "RiverGreen Agent",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#f8fafc",
      "showSpinner": true,
      "spinnerColor": "#6366f1"
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#ffffff"
    },
    "Permissions": {
      "phone": [
        "android.permission.CALL_PHONE",
        "android.permission.READ_PHONE_STATE",
        "android.permission.READ_CALL_LOG"
      ],
      "notifications": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    }
  }
}
